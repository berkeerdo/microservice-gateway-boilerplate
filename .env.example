# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
SERVICE_NAME=gateway-boilerplate
# SERVICE_VERSION is read from package.json

# ============================================
# SECURITY
# ============================================
# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT (for token validation/forwarding)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ISSUER=gateway

# Rate Limiting - General API
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Rate Limiting - Auth endpoints (stricter)
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_AUTH_WINDOW_MS=60000

# Trust Proxy (for correct client IP extraction)
# Options: false, true, loopback, number, comma-separated IPs/CIDRs
TRUST_PROXY=loopback

# ============================================
# MICROSERVICE ENDPOINTS
# ============================================
# Example Service (replace with your actual services)
EXAMPLE_SERVICE_GRPC_URL=localhost:50051
# EXAMPLE_SERVICE_HTTP_URL=http://localhost:3001

# ============================================
# gRPC CLIENT SETTINGS
# ============================================
GRPC_CLIENT_TIMEOUT_MS=5000
GRPC_CLIENT_RETRY_COUNT=3
GRPC_CLIENT_RETRY_DELAY_MS=1000

# TLS for gRPC - MUST be true in production
GRPC_USE_TLS=false
# GRPC_TLS_CA_PATH=/path/to/ca.crt
# GRPC_TLS_CLIENT_CERT_PATH=/path/to/client.crt
# GRPC_TLS_CLIENT_KEY_PATH=/path/to/client.key

# Keepalive settings
GRPC_KEEPALIVE_TIME_MS=10000
GRPC_KEEPALIVE_TIMEOUT_MS=5000

# ============================================
# CIRCUIT BREAKER SETTINGS
# ============================================
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=30000
CIRCUIT_BREAKER_HALF_OPEN_SUCCESS_THRESHOLD=3
CIRCUIT_BREAKER_FAILURE_WINDOW_MS=60000

# ============================================
# HTTP FALLBACK SETTINGS
# ============================================
HTTP_FALLBACK_ENABLED=true
HTTP_FALLBACK_TIMEOUT_MS=10000

# ============================================
# REDIS (for rate limiting & caching)
# ============================================
REDIS_SERVER=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_ENABLED=true

# ============================================
# OBSERVABILITY
# ============================================
# OpenTelemetry (Jaeger, Grafana Tempo, etc.)
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer xxx

# Sentry Error Tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE is auto-configured based on NODE_ENV

# ============================================
# COOKIE SETTINGS
# ============================================
# COOKIE_DOMAIN=.example.com  # For production cross-subdomain
COOKIE_SECURE=false  # Set to true in production (HTTPS only)
COOKIE_SAME_SITE=lax
COOKIE_ACCESS_TOKEN_MAX_AGE=900      # 15 minutes
COOKIE_REFRESH_TOKEN_MAX_AGE=604800  # 7 days

# ============================================
# MISC
# ============================================
TIMEZONE=+00:00
SHUTDOWN_TIMEOUT_MS=30000
